<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Oui / Non Button</title>
<style>
  body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: #f5f5f5;
    font-family: sans-serif;
  }

  button {
    padding: 10px 20px;
    font-size: 20px;
    margin: 20px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #non {
    background-color: #ff4d4d;
    color: white;
    border: none;
    border-radius: 5px;
  }

  #oui {
    background-color: #4CAF50;
    color: white;
    border: none;
    border-radius: 5px;
  }

</style>
</head>
<body>

<button id="oui">Oui</button>
<button id="non">Non</button>

<script>
  const ouiButton = document.getElementById('oui');
  const nonButton = document.getElementById('non');

  nonButton.addEventListener('click', () => {
    ouiButton.style.transform = 'scale(2)';  // تكبر Oui
    ouiButton.style.fontSize = '40px';       // تكبر الكتابة ديال Oui
  });
</script>

</body>
</html>
